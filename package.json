{
  "name": "arboretum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal plant-mapping PWA built on Cloudflare's free tier. See plans/arboretum_prd.md.",
  "scripts": {
    "start": "concurrently --names worker,spa --prefix-colors blue,green --kill-others-on-fail \"pnpm wrangler\" \"pnpm dev\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "admin:backup": "node scripts/backup.mjs",
    "seed": "node scripts/seed-dev.mjs",
    "wrangler": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:list": "wrangler d1 execute DB --local --command \"SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' AND name NOT LIKE 'd1_%' ORDER BY name\"",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "h3-js": "^4.4.0",
    "hono": "^4.6.14",
    "maplibre-gl": "^5.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  }
}
